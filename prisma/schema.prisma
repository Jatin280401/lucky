// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Site-wide configurable content
model SiteConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

// Satta games with results
model SattaGame {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  time      String
  yesterday String?
  today     String?
  order     Int      @default(0)
  category  String   // "main" or "second"
  updatedAt DateTime @updatedAt
}

// Daily result records for charts
model DailyResult {
  id        String   @id @default(cuid())
  date      String
  gameSlug  String
  result    String?
  updatedAt DateTime @updatedAt
  @@unique([date, gameSlug])
}

// Live result boxes (alwar, mandi bazar, etc.)
model LiveResult {
  id        String   @id @default(cuid())
  name      String
  result    String?
  time      String?
  order     Int      @default(0)
  updatedAt DateTime @updatedAt
}

// Content sections (FAQ, descriptions, etc.)
model ContentSection {
  id        String   @id @default(cuid())
  key       String   @unique
  title     String?
  content   String
  order     Int      @default(0)
  updatedAt DateTime @updatedAt
}

// Admin users are managed by Clerk - we just need to track who has admin access
model AdminUser {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String
  updatedAt DateTime @updatedAt
}
